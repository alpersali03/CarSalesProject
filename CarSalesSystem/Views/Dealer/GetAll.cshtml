@model List<CarSalesSystem.DTOs.DealerDto>

@{
    ViewData["Title"] = "Dealers";
}

<section class="section-shell">
    <div class="container-xl">
        <div class="section-head">
            <div>
                <span class="eyebrow">Dealer network</span>
                <h1>Meet the dealers</h1>
                <p class="section-copy">Browse the most active dealers, check their public profile, and see who is consistently listing fresh inventory.</p>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Dealer" asp-action="MyDashboard" class="btn btn-outline-dark">My dashboard</a>
            }
        </div>

        <div class="dealer-grid">
            @foreach (var dealer in Model)
            {
                <article class="dealer-card">
                    <div class="dealer-card-top">
                        <div>
                            <h3>@dealer.Name</h3>
                            <p>@dealer.CompanyName</p>
                        </div>
                        <span class="dealer-pill">@dealer.ActiveListingsCount live</span>
                    </div>
                    <div class="dealer-stats">
                        <div><strong>@dealer.SoldCarsCount</strong><span>sold</span></div>
                        <div><strong>@dealer.PhoneNumber</strong><span>phone</span></div>
                    </div>
                    <div class="catalog-secondary-actions">
                        <a asp-controller="Dealer" asp-action="Details" asp-route-id="@dealer.Id">Public profile</a>
                        @if (dealer.UserId == User.GetId())
                        {
                            <a asp-controller="Dealer" asp-action="Edit" asp-route-id="@dealer.Id">Edit profile</a>
                        }
                    </div>
                </article>
            }
        </div>
    </div>
</section>
