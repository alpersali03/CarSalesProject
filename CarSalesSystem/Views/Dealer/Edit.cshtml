@model CarSalesSystem.DTOs.DealerDto

@{
    ViewData["Title"] = "Edit Dealer Profile";
}

<section class="section-shell section-shell-tight">
    <div class="container-xl">
        <div class="section-head">
            <div>
                <span class="eyebrow">Dealer Profile</span>
                <h1>Update Your Showroom</h1>
                <p class="section-copy">Refresh your contact details and branding so buyers always see the latest profile information.</p>
            </div>
        </div>

        <div class="form-shell">
            <div class="form-card form-card-narrow">
                <form method="post" class="stack-form">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div>
                        <label asp-for="Name"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="small text-danger"></span>
                    </div>

                    <div>
                        <label asp-for="CompanyName"></label>
                        <input asp-for="CompanyName" class="form-control" />
                        <span asp-validation-for="CompanyName" class="small text-danger"></span>
                    </div>

                    <div>
                        <label asp-for="PhoneNumber"></label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="small text-danger"></span>
                    </div>

                    <div class="action-row">
                        <a asp-action="MyDashboard" class="btn btn-outline-secondary">Back to Dashboard</a>
                        <button type="submit" class="btn btn-dark">Save Profile</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
