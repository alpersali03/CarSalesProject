@model CarSalesSystem.DTOs.CarFormDto

@{
    ViewData["Title"] = "Edit Listing";
}

<section class="section-shell section-shell-tight">
    <div class="container-xl">
        <div class="section-head">
            <div>
                <span class="eyebrow">Dealer Tools</span>
                <h1>Edit Listing</h1>
                <p class="section-copy">Update pricing, specs, and presentation without changing ownership of the vehicle.</p>
            </div>
        </div>

        <div class="form-shell">
            <div class="form-card">
                <form asp-action="Edit" method="post" class="stack-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-grid-wide">
                        <div>
                            <label asp-for="Brand"></label>
                            <input asp-for="Brand" class="form-control" />
                            <span asp-validation-for="Brand" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Model"></label>
                            <input asp-for="Model" class="form-control" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>
                        <div class="form-span-full">
                            <label asp-for="Description"></label>
                            <textarea asp-for="Description" class="form-control form-textarea"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        <div class="form-span-full">
                            <label asp-for="ImageUrl"></label>
                            <input asp-for="ImageUrl" class="form-control" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Year"></label>
                            <input asp-for="Year" class="form-control" />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Mileage"></label>
                            <input asp-for="Mileage" class="form-control" />
                            <span asp-validation-for="Mileage" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="FuelType"></label>
                            <input asp-for="FuelType" class="form-control" />
                            <span asp-validation-for="FuelType" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Transmission"></label>
                            <input asp-for="Transmission" class="form-control" />
                            <span asp-validation-for="Transmission" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Price"></label>
                            <input asp-for="Price" class="form-control" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="CategoryId"></label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="Country"></label>
                            <input asp-for="Country" class="form-control" />
                            <span asp-validation-for="Country" class="text-danger small"></span>
                        </div>
                        <div>
                            <label asp-for="City"></label>
                            <input asp-for="City" class="form-control" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                    </div>

                    <label class="filter-check">
                        <input asp-for="IsListed" />
                        Keep this listing visible to buyers
                    </label>

                    <div class="action-row">
                        <a asp-action="GetAll" class="btn btn-outline-secondary">Back to Cars</a>
                        <button type="submit" class="btn btn-dark">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
