@model CarSalesSystem.Data.Model.Car
@{
    ViewData["Title"] = $"{Model.Brand} {Model.Model}";
}

<div class="details-page">
    <div class="details-header">
        <h1>@Model.Brand @Model.Model</h1>
        <div class="subtitle">@Model.Year &nbsp;•&nbsp; @Model.FuelType &nbsp;•&nbsp; @Model.City, @Model.Country</div>
    </div>
    <div class="details-layout">

        <div>
            <div class="details-image">
                <img src="@Model.ImageUrl" alt="@Model.Brand @Model.Model" onerror="this.src='/images/no-image.png'" />
            </div>
            <div class="price-badge">@Model.Price.ToString("N2") BGN</div>
        </div>

        <div class="details-info">
            <div class="section-label">Specifications</div>
            <table class="spec-table">
                <tr><td>Brand</td><td>@Model.Brand</td></tr>
                <tr><td>Model</td><td>@Model.Model</td></tr>
                <tr><td>Year</td><td>@Model.Year</td></tr>
                <tr><td>Mileage</td><td>@Model.Mileage.ToString("N0") km</td></tr>
                <tr><td>Fuel Type</td><td>@Model.FuelType</td></tr>
                <tr><td>Transmission</td><td>@Model.Transmission</td></tr>
                <tr><td>Category</td><td>@Model.Category?.Name</td></tr>
                <tr><td>Dealer</td><td>@Model.Dealer?.Name</td></tr>
                <tr><td>City</td><td>@Model.City</td></tr>
                <tr><td>Country</td><td>@Model.Country</td></tr>
            </table>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="section-label" style="margin-top:16px;">Description</div>
                <div class="description-box">@Model.Description</div>
            }

            <div class="action-row">
                <a asp-controller="Car" asp-action="GetAll" class="btn-back">← Back</a>
                <a asp-controller="Payment" asp-action="Buy" asp-route-carId="@Model.Id" class="btn-buy-big">Buy Now</a>
            </div>
        </div>

    </div>
</div>
