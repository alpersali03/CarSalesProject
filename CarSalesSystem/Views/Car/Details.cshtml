@model CarSalesSystem.Data.Model.Car

@{
    ViewData["Title"] = $"{Model.Brand} {Model.Model}";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var isFavorite = ViewBag.IsFavorite is bool favorite && favorite;
}

<section class="section-shell">
    <div class="container-xl">
        <div class="details-page details-page-modern">
            <div>
                <div class="details-image">
                    <img src="@Model.ImageUrl" alt="@Model.Brand @Model.Model" onerror="this.src='/image/photo3.jpg'" />
                </div>
            </div>

            <div class="details-info">
                <span class="eyebrow">Listing details</span>
                <h1>@Model.Brand @Model.Model</h1>
                <p class="section-copy">@Model.Year · @Model.FuelType · @Model.Transmission · @Model.Mileage.ToString("N0") km</p>
                <div class="price-callout">@Model.Price.ToString("N0") BGN</div>

                <div class="spec-table spec-table-modern">
                    <div><span>Dealer</span><strong>@Model.Dealer?.Name</strong></div>
                    <div><span>Category</span><strong>@Model.Category?.Name</strong></div>
                    <div><span>City</span><strong>@Model.City</strong></div>
                    <div><span>Country</span><strong>@Model.Country</strong></div>
                </div>

                <div class="description-box">@Model.Description</div>

                <div class="action-row action-row-wrap">
                    <a asp-controller="Payment" asp-action="Buy" asp-route-carId="@Model.Id" class="btn btn-warning">Buy now</a>
                    <a asp-controller="Dealer" asp-action="Details" asp-route-id="@Model.DealerId" class="btn btn-outline-dark">Dealer profile</a>
                    <button type="button" class="btn btn-outline-secondary" data-compare-button data-car-id="@Model.Id">Add to compare</button>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Favorite" asp-action="Toggle" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="carId" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="link-button">
                            @(isFavorite ? "Remove from favorites" : "Save to favorites")
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</section>
