@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<div class="auth-actions">
@if (SignInManager.IsSignedIn(User))
{
    <a class="auth-link auth-link-profile" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Profile</a>
    <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
        <button type="submit" class="auth-link auth-link-logout">Logout</button>
    </form>
}
else
{
    <a class="auth-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
    <a class="auth-link auth-link-primary" asp-area="Identity" asp-page="/Account/Register">Register</a>
}
</div>
