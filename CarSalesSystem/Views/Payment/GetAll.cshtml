@model IEnumerable<CarSalesSystem.Data.Model.Payment>

@{
    ViewData["Title"] = "All Payments";
}

<div class="container mt-5">
    <h2 class="text-center text-warning fw-bold">All Payments</h2>
    <hr class="mb-4">

    @if (!Model.Any())
    {
        <p class="text-center text-muted">No payments found.</p>
    }
    else
    {
        <table class="table table-dark table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Car</th>
                    <th>Total Amount</th>
                    <th>Payment Time</th>
                    <th>Successful</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model)
                {
                    <tr>
                        <td>@payment.Id</td>
                        <td>@payment.Car?.Model</td>
                        <td>@payment.TotalAmount.ToString("C")</td>
                        <td>@payment.PaymentTime.ToString("g")</td>
                        <td>@(payment.IsSuccessful ? "✅" : "❌")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@payment.Id"
                               class="btn btn-sm btn-outline-warning">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>