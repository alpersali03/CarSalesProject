@model IEnumerable<CarSalesSystem.Data.Model.Payment>

@{
    ViewData["Title"] = "Payments";
}

<section class="section-shell section-shell-tight">
    <div class="container-xl">
        @if (TempData["Error"] is string errorMessage)
        {
            <div class="alert alert-warning mb-4" role="alert">
                @errorMessage
            </div>
        }

        <div class="section-head">
            <div>
                <span class="eyebrow">Orders</span>
                <h1>Payment History</h1>
                <p class="section-copy">Review your completed purchases and open any transaction for the full receipt details.</p>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <h3>No purchases yet</h3>
                <p>Your successful payments will appear here after checkout.</p>
            </div>
        }
        else
        {
            <div class="payment-table-card">
                <table class="payment-table">
                    <thead>
                        <tr>
                            <th>Payment</th>
                            <th>Vehicle</th>
                            <th>Amount</th>
                            <th>Paid On</th>
                            <th>Card</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model)
                        {
                            <tr>
                                <td>#@payment.Id</td>
                                <td>@payment.Car?.Brand @payment.Car?.Model</td>
                                <td>@payment.TotalAmount.ToString("N2") BGN</td>
                                <td>@payment.PaymentTime.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                <td>**** @payment.CardLast4</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@payment.Id" class="btn btn-sm btn-outline-dark">
                                        Receipt
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
